general {
    colors = true
    interval = 5
    color_good = "#cdd6f4"
    color_degraded = "#f9e2af"
    color_bad = "#f38ba8"
}

order += "cpu_usage"
order += "memory"
order += "disk /"
order += "tztime local"

cpu_usage {
    format = "󰻠 %usage"
}

memory {
    format = "󰍛 %used/%total"
}

disk "/" {
    format = "󰋊 %free"
}

tztime local {
    format = "󰃰 %d/%m/%Y %H:%M"
}
